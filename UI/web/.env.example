# Palissage web — environment configuration
#
# Copy to `.env` (or `.env.local`) and fill in once the protocol is deployed.
# Defaults to Arbitrum One. While the core addresses are unset the app falls back
# to static demo data.

# --- Network -----------------------------------------------------------------
# Target chain id: 42161 = Arbitrum One (default), 421614 = Arbitrum Sepolia
# (also used for a local anvil fork of Sepolia).
VITE_CHAIN_ID=42161
# Optional private/override RPC. For an anvil fork set this to http://localhost:8545.
VITE_ARBITRUM_RPC_URL=

# WalletConnect Cloud project id (https://cloud.reown.com). Required for the
# WalletConnect/mobile-QR option; injected wallets (MetaMask/Rabby) work without it.
VITE_WALLETCONNECT_PROJECT_ID=

# --- Payment token -----------------------------------------------------------
# Monerium EUR emoney (EURe) — 18 decimals. Arbitrum Sepolia EURe:
# 0xFdEed5cE7E281B4e0F163B70eBe2Cf0B10803b7B
VITE_EURE_ADDRESS=

# --- Deployed Palissage contracts --------------------------------------------
# From `forge script script/Deploy.s.sol` console output.
VITE_WINE_LOT_TOKEN_ADDRESS=
VITE_PRIMARY_MARKET_ADDRESS=
VITE_SECONDARY_MARKET_ADDRESS=
VITE_REDEMPTION_MANAGER_ADDRESS=
VITE_IDENTITY_REGISTRY_ADDRESS=
VITE_TRUSTED_ISSUERS_REGISTRY_ADDRESS=
VITE_CLAIM_ISSUER_ADDRESS=
# RoleGateway — powers on-chain test mode + role switching + admin role granting.
VITE_ROLE_GATEWAY_ADDRESS=
